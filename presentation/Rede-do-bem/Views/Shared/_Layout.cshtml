<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Rede_do_bem</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/shared.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Rede_do_bem.styles.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Otomanopee+One&display=swap" rel="stylesheet">
    @await RenderSectionAsync("Styles", required: false)
<script type="text/javascript">
    (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
    })(window, document, "clarity", "script", "x93h10wzpo");
</script>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg rdb-navbar">
            <div class="container">
                <a class="navbar-brand rdb-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="rdb-brand-icon"><i class="bi bi-heart-fill"></i></span>
                    Rede do Bem
                </a>
                <button class="navbar-toggler rdb-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain"
                        aria-controls="navbarMain" aria-expanded="false" aria-label="Toggle navigation">
                    <i class="bi bi-list"></i>
                </button>
                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-1">

                        <li class="nav-item">
                            <a class="nav-link rdb-nav-link hide-mobile-nav" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door me-1"></i>Home
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link rdb-nav-link hide-mobile-nav" asp-controller="Dashboard" asp-action="Index">
                                <i class="bi bi-bar-chart-line me-1"></i>Dashboard
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link rdb-nav-link hide-mobile-nav" asp-controller="Perfil" asp-action="Redirecionar">
                                <i class="bi bi-person-circle me-1"></i>Meu Perfil
                            </a>
                        </li>

                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link rdb-nav-link rdb-notif-link position-relative" asp-controller="Notificacao" asp-action="Index">
                                    @{
                                        var dbContext = ViewContext.HttpContext.RequestServices
                                            .GetService(typeof(Rede_do_bem.Data.ApplicationDbContext)) as Rede_do_bem.Data.ApplicationDbContext;
                                        var emailAtual = User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value;
                                        var naoLidas = dbContext != null && emailAtual != null
                                            ? dbContext.Notificacoes.Count(n => n.UsuarioEmail == emailAtual && !n.Lida)
                                            : 0;
                                    }
                                    <i class="bi bi-bell@(naoLidas > 0 ? "-fill" : "") me-1"></i>Notificações
                                    @if (naoLidas > 0)
                                    {
                                        <span class="rdb-badge">@naoLidas</span>
                                    }
                                </a>
                            </li>
                            <li class="nav-item">
                                <form method="post" action="/Index?handler=Logout" class="d-flex align-items-center m-0 p-0">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="rdb-logout-btn" title="Sair da conta" formnovalidate>
                                        <i class="bi bi-box-arrow-right rdb-logout-icon-desktop d-none d-lg-inline"></i>
                                        <span class="d-lg-none"><i class="bi bi-box-arrow-right me-1"></i>Sair da Conta</span>
                                    </button>
                                </form>
                            </li>
                        }

                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- NAVBAR INFERIOR (mobile) -->
    <div class="bottom-nav">
        <a asp-controller="Dashboard" asp-action="Index" class="nav-item">
            <i class="bi bi-bar-chart-line"></i>
        </a>
        <a asp-page="/Index" class="nav-item">
            <i class="bi bi-house"></i>
        </a>
        <a asp-controller="Perfil" asp-action="Redirecionar" class="nav-item">
            <i class="bi bi-person"></i>
        </a>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('click', function (e) {
            var navbar = document.getElementById('navbarMain');
            var toggler = document.querySelector('.rdb-toggler');
            if (navbar && navbar.classList.contains('show') &&
                !navbar.contains(e.target) &&
                !toggler.contains(e.target)) {
                var bsCollapse = bootstrap.Collapse.getInstance(navbar);
                if (bsCollapse) bsCollapse.hide();
            }
        });

        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') {
                var navbar = document.getElementById('navbarMain');
                if (navbar && navbar.classList.contains('show')) {
                    var bsCollapse = bootstrap.Collapse.getInstance(navbar);
                    if (bsCollapse) bsCollapse.hide();
                }
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>