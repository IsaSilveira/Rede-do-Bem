ff@page
@model Rede_do_bem.Pages.DashboardModel

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">


<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Amatic+SC:wght@400;700&display=swap" rel="stylesheet">
<link href="https://fonts.cdnfonts.com/css/otomanopee-one" rel="stylesheet">


@section Styles {
    <link rel="stylesheet" href="~/css/pages/dashboard.css" asp-append-version="true" />
}

        <div class="topbar">
    <div class="logo"> <p>Tipo do usuário: @Model.TipoUsuario</p> </div>
    
        </div>


<div class="dashboard-container">

    <div class="card-dashboard verde">

        <h4>
            @if (Model.TipoUsuario == "Instituicao")
            {
                @:Perfil Salvo
            }
            else
            {
                @:Doações Feitas
            }
        </h4>

        <div class="circle">
            @Model.Card1
        </div>

    </div>

    <div class="card-dashboard azul">

        <h4>
            @if (Model.TipoUsuario == "Instituicao")
            {
                @:Campanhas Criadas
            }
            else
            {
                @:Campanhas Criadas
            }
        </h4>

        <div class="circle">
            @Model.Card2
        </div>

    </div>

    <div class="card-dashboard azul-claro">

        <h4>
            @if (Model.TipoUsuario == "Instituicao")
            {
                @:Doações Recebidas
            }
            else
            {
                @:Doações Recebidas
            }
        </h4>

        <div class="circle">
            @Model.Card3
        </div>
        
    </div>

</div>

