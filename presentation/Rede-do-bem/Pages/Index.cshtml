else
{
    <div class="d-lg-none">
        <div class="logo-container">
            <img src="~/assets/logo.png" alt="Rede do Bem" class="logo-img" />
        </div>
        
        <div class="tagline-images" style="margin-bottom: 60px!important; margin-top: 60px!important;">
            <img src="~/assets/start1.png" alt="Unindo mãos que doam" class="tagline-img me-auto" />
            <img src="~/assets/start2.png" alt="...a quem sabe entregar" class="tagline-img ms-auto" style="padding-left: 60px" />
