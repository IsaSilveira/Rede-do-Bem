@page
@model Rede_do_bem.Pages.Account.ResetPasswordModel
@{
    ViewData["Title"] = "Resetar Senha";
    Layout = "_AuthLayout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/account.css" asp-append-version="true" />
}

@section LeftSide {
    <div class="logo-container">
        <img src="~/assets/logo.png" alt="Rede do Bem" class="logo-img" />
    </div>
    <div class="welcome-text mb-0">Nova Senha</div>
    <p class="mt-3" style="opacity: 0.9; font-size: 1.2rem;">
        Defina uma nova senha para a conta de <span style="color: var(--rd-yellow); font-weight: bold;">@Model.AccountName</span>.
    </p>
}

<div class="d-lg-none">
    <div class="logo-container">
        <img src="~/assets/logo.png" alt="Rede do Bem" class="logo-img" />
    </div>
    <div class="welcome-text mb-1">Nova Senha</div>
    <p class="text-center px-4 mb-4" style="opacity: 0.9; font-size: 1.1rem; margin-top: -0.5rem;">
        Defina uma nova senha para a conta de <span style="color: var(--rd-yellow); font-weight: bold;">@Model.AccountName</span>.
    </p>
</div>

<div class="auth-form-container">
    <form method="post">
        <input type="hidden" asp-for="Input.Email" />
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

        <div class="account-reset-card mb-4 p-3 rounded-4 d-flex align-items-center gap-3">
            <div class="account-avatar d-flex align-items-center justify-content-center rounded-circle">
                <i class="bi bi-person-fill"></i>
            </div>
            <div class="account-details">
                <span class="account-badge text-uppercase">Redefinindo senha de</span>
                <h5 class="account-name mb-0">@Model.AccountName</h5>
                <span class="account-email">@Model.Input.Email</span>
            </div>
        </div>

        <div class="password-container">
            <input asp-for="Input.Password" type="password" class="auth-input" placeholder="Nova senha" id="resetPassword" />
            <button type="button" class="password-toggle" onclick="togglePassword('resetPassword', this)">
                <i class="bi bi-eye mt-1"></i>
            </button>
        </div>
        <span asp-validation-for="Input.Password" class="text-danger small"></span>

        <div class="password-container">
            <input asp-for="Input.ConfirmPassword" type="password" class="auth-input" placeholder="Confirmar nova senha" id="confirmResetPassword" />
            <button type="button" class="password-toggle" onclick="togglePassword('confirmResetPassword', this)">
                <i class="bi bi-eye mt-1"></i>
            </button>
        </div>
        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>

        <div class="d-flex flex-column align-items-center mt-3">
            <button type="submit" class="btn btn-rd-primary">Alterar Senha</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePassword(inputId, button) {
            const input = document.getElementById(inputId);
            const icon = button.querySelector('i');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.remove('bi-eye');
                icon.classList.add('bi-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.remove('bi-eye-slash');
                icon.classList.add('bi-eye');
            }
        }
    </script>
}
