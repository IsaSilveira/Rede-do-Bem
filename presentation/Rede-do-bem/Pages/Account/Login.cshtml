@page
@model Rede_do_bem.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Entrar";
    Layout = "_AuthLayout";
}

@section LeftSide {
    <div class="logo-container">
        <img src="~/assets/logo.png" alt="Rede do Bem" class="logo-img" />
    </div>
    <div class="welcome-text mb-0">Bem-vindo de volta!</div>
    <p class="mt-3" style="opacity: 0.8; font-size: 1.2rem;">Acesse sua conta para continuar transformando vidas.</p>
}

<div class="d-lg-none pt-4 mt-3" style="position: relative; z-index: 2;">
    <div class="logo-container">
        <img src="~/assets/logo.png" alt="Rede do Bem" class="logo-img" />
    </div>
    <div class="welcome-text">Bem-vindo de volta!</div>
</div>

<div class="auth-form-container">
    <form method="post">
        <div asp-validation-summary="ModelOnly"></div>
        
        <input asp-for="Input.Email" class="auth-input" placeholder="Seu e-mail" />
        <span asp-validation-for="Input.Email" class="text-danger small"></span>

        <div class="password-container">
            <input asp-for="Input.Password" type="password" class="auth-input" placeholder="Sua senha" id="Input_Password" />
            <button type="button" class="password-toggle" onclick="togglePassword('Input_Password', this)">
                <i class="bi bi-eye mt-1"></i>
            </button>
        </div>
        <span asp-validation-for="Input.Password" class="text-danger small"></span>

        <div class="text-center mb-4">
            <a asp-page="./ForgotPassword" class="auth-link">Esqueci minha senha</a>
        </div>

        <div class="d-flex flex-column align-items-center">
            <button type="submit" class="btn btn-rd-primary">Login</button>
            <div class="mt-3 text-center">
                <span class="small">Não tem cadastro?</span><br />
                <a asp-page="./RegisterChoice" class="auth-link fw-bold">Se cadastrar.</a>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePassword(inputId, button) {
            const input = document.getElementById(inputId);
            const icon = button.querySelector('i');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.remove('bi-eye');
                icon.classList.add('bi-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.remove('bi-eye-slash');
                icon.classList.add('bi-eye');
            }
        }
    </script>
}
