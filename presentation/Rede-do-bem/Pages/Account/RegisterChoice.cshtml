@page
@model Rede_do_bem.Pages.Account.RegisterChoiceModel
@{
    ViewData["Title"] = "Definição de Perfil";
    Layout = "_AuthLayout";
}

@section LeftSide {
    <div class="logo-container">
        <img src="~/assets/logo.png" alt="Rede do Bem" class="logo-img" />
    </div>
    <div class="welcome-text mb-3">Escolha seu perfil</div>
    <p style="opacity: 0.8; font-size: 1.2rem; max-width: 500px;">Precisamos saber um pouco mais sobre você para criar a melhor experiência.</p>
}

<div class="d-lg-none">
    <div class="logo-container">
        <img src="~/assets/logo.png" alt="Rede do Bem" class="logo-img" />
    </div>
    <div class="welcome-text">Escolha seu perfil</div>
</div>

<div class="profile-choice-container">
    <div class="profile-badge">Vamos entender o seu perfil!</div>

    <h2 class="profile-choice-title">Qual das alternativas abaixo você se identifica?</h2>

    <a asp-page="./Register" asp-route-tipo="0" class="profile-card" id="choice-doador">
        <div class="profile-card-content">
            <strong class="profile-card-heading">Eu quero transformar!</strong>
            <p class="profile-card-desc">'Quero encontrar causas próximas e mobilizar doações para quem precisa.'</p>
        </div>
        <span class="profile-card-arrow">→</span>
    </a>

    <a asp-page="./Register" asp-route-tipo="1" class="profile-card" id="choice-instituicao">
        <div class="profile-card-content">
            <strong class="profile-card-heading">Eu sou um ponto do bem!</strong>
            <p class="profile-card-desc">'Somos uma organização/coletivo e precisamos de apoio para nossas ações.'</p>
        </div>
        <span class="profile-card-arrow">→</span>
    </a>

    <div class="mt-3 text-center">
        <a asp-page="./Login" class="auth-link fw-bold">Já tenho conta.</a>
    </div>
</div>
